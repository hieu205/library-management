{
  "info": {
    "name": "Library Management API",
    "_postman_id": "library-management-v1",
    "description": "Toàn bộ API của hệ thống quản lý thư viện. Base URL: http://localhost:8080\n\nXác thực: HTTP Basic Auth (username + password)\n- Tài khoản test: admin / Password@123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"testuser@gmail.com\",\n  \"password\": \"Password@123\",\n  \"fullName\": \"Người Dùng Test\",\n  \"phone\": \"0909999999\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Đăng ký tài khoản mới. Không cần xác thực."
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Password@123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Đăng nhập. Không cần xác thực."
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "admin", "type": "string" },
                { "key": "password", "value": "Password@123", "type": "string" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "me"]
            },
            "description": "Lấy thông tin profile của user đang đăng nhập. Cần Basic Auth."
          }
        },
        {
          "name": "Update My Profile",
