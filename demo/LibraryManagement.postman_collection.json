              "path": ["api", "v1", "users", "10", "status"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isActive\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Khoá / mở khoá tài khoản user theo ID (chỉ Admin). Thay :id trong URL."
          }
        }
      ]
    },
