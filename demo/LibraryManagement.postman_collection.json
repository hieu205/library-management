        },
        {
          "name": "Update User Status (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "admin", "type": "string" },
