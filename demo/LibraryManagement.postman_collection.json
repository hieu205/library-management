              "mode": "raw",
              "raw": "{\n  \"username\": \"user1\",\n  \"email\": \"user1_new@gmail.com\",\n  \"password\": \"NewPass@456\",\n  \"fullName\": \"Nguyễn Văn An\",\n  \"phone\": \"0901111115\"\n}",
              "options": { "raw": { "language": "json" } }
